---
// TriviaCallout.astro — V7 Trivia engagement component
// Props: text (string), source (string, optional)

interface Props {
  text: string;
  source?: string;
}

const { text, source } = Astro.props;
---

<div class="trivia-callout">
  <div class="trivia-label">
    <svg class="compass-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M12 2v20M2 12h20M12 6l3 6-3 6-3-6 3-6z"></path>
    </svg>
    <span>DID YOU KNOW?</span>
  </div>
  <p class="trivia-text">{text}</p>
  {source && <p class="trivia-source">— {source}</p>}
</div>

<style scoped>
  .trivia-callout {
    max-width: 320px;
    background-color: rgba(212, 165, 116, 0.15);
    border-radius: 0.5rem;
    padding: 1.25rem;
  }

  .trivia-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #d4a574;
    margin-bottom: 0.75rem;
  }

  .compass-icon {
    flex-shrink: 0;
    color: #d4a574;
  }

  .trivia-text {
    margin: 0;
    font-size: 0.875rem;
    color: #4a4a4a;
    line-height: 1.6;
  }

  .trivia-source {
    margin: 0.75rem 0 0 0;
    font-size: 0.75rem;
    color: #7a7a7a;
    font-style: italic;
  }

  @media (min-width: 768px) {
    .trivia-callout {
      max-width: 100%;
    }
  }
</style>
