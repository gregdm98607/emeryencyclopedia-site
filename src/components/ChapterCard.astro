---
// ChapterCard.astro — V5 Chapter card component with part-colored left border, status badge, and reading time

import { getPartColor } from '../utils/parts';

interface Props {
  chapter: number;
  title: string;
  part: number;
  status: string;
  description: string;
  wordCount?: number;
}

const { chapter, title, part, status, description, wordCount = 0 } = Astro.props;

// Determine if card is linkable and calculate reading time
const isLinkable = ['final', 'draft', 'revised', 'fact-checked'].includes(status);
const readingTime = wordCount > 0 ? Math.ceil(wordCount / 230) : 0;

// Status badge styling
const statusStyles: Record<string, { bgClass: string; textClass: string; label: string }> = {
  'final': { bgClass: 'bg-sage-green', textClass: 'text-white', label: 'Available' },
  'draft': { bgClass: 'bg-sage-green', textClass: 'text-white', label: 'Available' },
  'revised': { bgClass: 'bg-sage-green', textClass: 'text-white', label: 'Available' },
  'fact-checked': { bgClass: 'bg-sage-green', textClass: 'text-white', label: 'Available' },
  'stub': { bgClass: 'border-2 border-sandstone', textClass: 'text-sandstone', label: 'Coming Soon' }
};

const currentStatus = statusStyles[status] || statusStyles['stub'];
const partColor = getPartColor(part);

const CardElement = isLinkable ? 'a' : 'div';
const cardProps = isLinkable ? { href: `/chapters/${chapter}` } : {};
---

<CardElement
  {...cardProps}
  class={`chapter-card ${isLinkable ? 'chapter-card--linkable' : ''}`}
  style={`--part-color: ${partColor}`}
>
  {/* Left colored border */}
  <div class="chapter-card__border"></div>

  {/* Chapter number */}
  <div class="chapter-card__number">{chapter}</div>

  {/* Status badge */}
  <div class={`chapter-card__badge ${currentStatus.bgClass} ${currentStatus.textClass}`}>
    {currentStatus.label}
  </div>

  {/* Content area */}
  <div class="chapter-card__content">
    <h3 class="chapter-card__title">{title}</h3>
    <p class="chapter-card__description">{description}</p>
  </div>

  {/* Footer with reading time */}
  {wordCount > 0 && (
    <div class="chapter-card__footer">
      <span class="chapter-card__read-time">{readingTime} min read</span>
    </div>
  )}
</CardElement>

<style>
  :root {
    --sandstone: #D4A574;
    --mesa-red: #C85A54;
    --coal-seam: #1A1A2E;
    --sky-wash: #F7F3ED;
    --forest-green: #4A6741;
    --sky-blue: #5B8AC5;
    --canyon-bronze: #8B6F47;
    --sage-green: #6B9B6F;
    --font-display: 'Libre Baskerville', serif;
    --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .chapter-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background: white;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .chapter-card--linkable {
    cursor: pointer;
    text-decoration: none;
  }

  .chapter-card--linkable:hover {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
    transform: translateY(-2px);
  }

  /* Left colored border */
  .chapter-card__border {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background-color: var(--part-color);
  }

  /* Chapter number */
  .chapter-card__number {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-size: 2rem;
    font-weight: 700;
    color: rgba(26, 26, 46, 0.15);
    font-family: var(--font-body);
    line-height: 1;
  }

  /* Status badge */
  .chapter-card__badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.375rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .chapter-card__badge.bg-sage-green {
    background-color: var(--sage-green);
    color: white;
  }

  .chapter-card__badge.border-2 {
    background: transparent;
    border: 2px solid var(--sandstone);
  }

  .chapter-card__badge.text-sandstone {
    color: var(--sandstone);
  }

  /* Content area */
  .chapter-card__content {
    flex: 1;
    padding: 1.5rem 1.5rem 0 1.5rem;
    display: flex;
    flex-direction: column;
  }

  /* Title */
  .chapter-card__title {
    margin: 0 0 0.75rem 0;
    font-size: 1.125rem;
    font-weight: 600;
    font-family: var(--font-display);
    color: var(--coal-seam);
    line-height: 1.4;
  }

  /* Description */
  .chapter-card__description {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgba(26, 26, 46, 0.7);
    font-family: var(--font-body);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }

  /* Footer with reading time */
  .chapter-card__footer {
    padding: 1rem 1.5rem 1.5rem 1.5rem;
    border-top: 1px solid rgba(212, 165, 116, 0.1);
  }

  /* Reading time indicator */
  .chapter-card__read-time {
    font-size: 0.75rem;
    color: rgba(26, 26, 46, 0.5);
    font-family: var(--font-body);
    font-weight: 500;
  }
</style>
